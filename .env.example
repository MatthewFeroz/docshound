APP_ENV=development

# Required for higher GitHub rate limits. Public unauthenticated requests work for small demos.
GITHUB_TOKEN=

# Optional. Enables creating documentation branches and pull requests.
# Use a fine-grained token with Contents and Pull requests read/write access.
GITHUB_WRITE_TOKEN=

# Optional. Enables LLM clustering instead of heuristic clustering.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
